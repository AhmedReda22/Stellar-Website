# Hoist common dependencies so libraries that expect flat node_modules work.
# Next.js, React, and most React libs need this to find peer dependencies.
shamefully-hoist=true

# Auto-install peer deps (Next 15 + React 19 ecosystem still has gaps here).
auto-install-peers=true

# Don't fail install on minor peer dep mismatches (common with React 19).
strict-peer-dependencies=false
